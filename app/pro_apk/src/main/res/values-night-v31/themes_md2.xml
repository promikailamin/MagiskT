        <item name="colorPrimary">@android:color/system_accent1_200</item>
        <item name="colorPrimaryVariant">@android:color/system_accent1_700</item>

        <item name="colorSecondary">@android:color/system_accent2_200</item>
        <item name="colorSecondaryVariant">@android:color/system_accent2_700</item>

        <item name="colorSurface">@android:color/system_neutral1_900</item>
        <item name="colorSurfaceVariant">@android:color/system_neutral1_800</item>

        <item name="colorOnPrimary">@android:color/system_accent1_900</item>
        <item name="colorOnSecondary">@android:color/system_accent2_900</item>

        <item name="colorOnSurface">@android:color/system_neutral1_50</item>
        <item name="colorOnSurfaceVariant">@android:color/system_neutral2_200</item>

